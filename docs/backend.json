
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "بيانات المستخدم الأساسية والرصيد المالي.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "balance": { "type": "number", "description": "الرصيد المتاح بالجنيه المصري" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "balance", "role"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "جلسة محادثة ذكية محفوظة.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "characterId": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      }
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "طلب شحن رصيد مرسل من المستخدم للمالك.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "ملفات المستخدمين"
    },
    "/users/{userId}/chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "جلسات الدردشة الخاصة بكل مستخدم"
    },
    "/paymentRequests/{requestId}": {
      "schema": "PaymentRequest",
      "description": "طلبات الشحن العامة للمدير"
    },
    "/consultantProfiles/{consultantId}": {
      "schema": "object",
      "description": "بيانات الخبراء المتاحين"
    }
  }
}
