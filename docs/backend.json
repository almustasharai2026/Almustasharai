{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "الملف السيادي للمواطن الرقمي، يضم الهوية الرقمية ومستوى الثقة.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "consultant", "admin"] },
        "balance": { "type": "number", "default": 50 },
        "isBanned": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "Consultant": {
      "title": "Consultant",
      "description": "ملف الخبير المعتمد في هيئة الاستشارات.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "rating": { "type": "number", "default": 5.0 },
        "isApproved": { "type": "boolean", "default": true }
      },
      "required": ["name", "specialization"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "المحفظة المالية المستقلة.",
      "type": "object",
      "properties": {
        "balance": { "type": "number", "default": 0 },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "بيانات الهوية السيادية"
    },
    "/consultants/{id}": {
      "schema": "Consultant",
      "description": "هيئة الخبراء المعتمدين"
    },
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "المحافظ المالية المستقلة"
    }
  }
}