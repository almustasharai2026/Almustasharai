
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "الملف السيادي للمواطن الرقمي، يضم الرصيد، الهوية الرقمية، ومستوى الثقة.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "digitalId": { "type": "string", "description": "Unique Sovereign ID" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "balance": { "type": "number", "default": 50 },
        "role": { "type": "string", "enum": ["user", "consultant", "admin"] },
        "trustScore": { "type": "number", "default": 100 },
        "isBanned": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActivity": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "digitalId", "email", "fullName", "balance", "role"]
    },
    "ConsultantProfile": {
      "title": "ConsultantProfile",
      "description": "ملف الخبير المعتمد في المنصة.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "bio": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "rating": { "type": "number", "default": 5.0 },
        "totalSessions": { "type": "number", "default": 0 },
        "isApproved": { "type": "boolean", "default": false },
        "isOnline": { "type": "boolean", "default": false }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "سجل المعاملات المالية داخل النظام البيئي.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["recharge", "deduction", "refund"] },
        "service": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "طلب شحن رصيد مقدم من المواطن.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "بيانات المواطنين الرقميين"
    },
    "/users/{userId}/transactions/{id}": {
      "schema": "Transaction",
      "description": "سجل المحاسبة المالية"
    },
    "/paymentRequests/{id}": {
      "schema": "PaymentRequest",
      "description": "طلبات الشحن المعلقة"
    },
    "/consultantProfiles/{id}": {
      "schema": "ConsultantProfile",
      "description": "هيئة الخبراء"
    },
    "/system/moderation/forbiddenWords/{id}": {
      "schema": "object",
      "description": "قاموس الحظر التلقائي"
    }
  }
}
