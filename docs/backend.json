{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "الملف السيادي للمواطن الرقمي، يضم الهوية الرقمية ومستوى الثقة وحالة الامتثال.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "consultant", "moderator", "admin"] },
        "balance": { "type": "number", "default": 50 },
        "trustScore": { "type": "number", "default": 50 },
        "completedSessions": { "type": "number", "default": 0 },
        "reports": { "type": "number", "default": 0 },
        "isBanned": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "Consultant": {
      "title": "Consultant",
      "description": "ملف الخبير المعتمد في هيئة الاستشارات.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "rating": { "type": "number", "default": 5.0 },
        "reviews": { "type": "number", "default": 0 },
        "isApproved": { "type": "boolean", "default": true }
      },
      "required": ["name", "specialization"]
    },
    "ModerationWord": {
      "title": "ModerationWord",
      "description": "كلمة محظورة يراقبها الدرع الواقي السيادي.",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "سجل حجز جلسة استشارية بين مواطن وخبير.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "consultantId": { "type": "string" },
        "sessionId": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled", "active"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "consultantId", "price", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "سجل حركة مالية داخل المحفظة السيادية.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "service": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "بيانات الهوية السيادية"
    },
    "/wallets/{userId}": {
      "schema": "object",
      "description": "المحفظة المالية السيادية"
    },
    "/wallets/{userId}/transactions/{id}": {
      "schema": "Transaction",
      "description": "سجل المعاملات المالية المفصل"
    },
    "/consultants/{id}": {
      "schema": "Consultant",
      "description": "هيئة الخبراء المعتمدين"
    },
    "/system/moderation/forbiddenWords/{id}": {
      "schema": "ModerationWord",
      "description": "قاعدة بيانات الكلمات المحظورة"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "سجلات الحجز السيادي"
    },
    "/analytics/{id}": {
      "schema": "object",
      "description": "سجلات التحليلات والنشاط البرمجي"
    }
  }
}
