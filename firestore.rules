
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sovereign Access Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'bishoysamy390@gmail.com'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // بروتوكول التحقق من حالة المواطن (Resilient Banned Check)
    // يسمح بالوصول في حال عدم وجود الوثيقة (للمواطنين الجدد) أو إذا لم يكن محظوراً
    function isNotBanned() { 
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.get('isBanned', false) == false; 
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn();
      allow update: if (isOwner(userId) && isNotBanned()) || isAdmin();
    }

    // Wallets Protocol (Sovereign Financial Security)
    match /wallets/{userId} {
      allow read, write: if (isOwner(userId) && isNotBanned()) || isAdmin();
      
      // تأمين سجل المعاملات (Sub-collection Access)
      match /transactions/{transactionId} {
        allow read, write: if (isOwner(userId) && isNotBanned()) || isAdmin();
      }
    }

    // Bookings Protocol (Signed-in access)
    match /bookings/{id} {
      allow create, read: if isSignedIn() && isNotBanned();
      allow update, delete: if isAdmin();
    }

    // Consultants Registry (Public read, Admin write)
    match /consultants/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Global Moderation System
    match /system/moderation/forbiddenWords/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Live Consultations
    match /liveConsultations/{sessionId} {
      allow read, write: if isSignedIn() && isNotBanned();
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && isNotBanned();
      }
    }

    // Analytics Protocol
    match /analytics/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}
