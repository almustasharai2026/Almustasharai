
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sovereign Access Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'bishoysamy390@gmail.com'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isNotBanned() { 
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return user != null && user.data.isBanned == false; 
    }

    // Role-based Path Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn();
      allow update: if (isOwner(userId) && isNotBanned() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'role', 'digitalId', 'isBanned', 'trustScore'])) || isAdmin();
      
      match /transactions/{id} { allow read: if isOwner(userId) || isAdmin(); }
      match /contracts/{id} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /chatSessions/{id} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    match /consultantProfiles/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == id);
    }

    match /system/moderation/forbiddenWords/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /liveConsultations/{id} {
      allow read, write: if isSignedIn() && isNotBanned();
    }
    
    match /decisions/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isNotBanned();
    }
  }
}
