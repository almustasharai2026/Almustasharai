
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // المواطنون
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /chatHistory/{msgId} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    // نظام الحجز والجدولة (Sovereign Booking System)
    match /bookings/{bookingId} {
      // المواطن يرى حجوزاته، الخبير يرى الموجهة له، المدير يرى الكل
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.consultantId == request.auth.uid || 
        isAdmin()
      );
      // المواطن يستطيع إنشاء حجز
      allow create: if isSignedIn();
      // الخبير والمدير يستطيعون التحديث (إلغاء، تعديل حالة)
      allow update: if isSignedIn() && (
        resource.data.consultantId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // طلبات الدفع
    match /paymentRequests/{reqId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /consultants/{id} { allow read: if true; allow write: if isAdmin(); }
    match /roles_admin/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}
