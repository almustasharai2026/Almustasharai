
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "بيانات المستخدم الأساسية والرصيد المالي وحالة الحظر.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isBanned": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "balance", "role"]
    },
    "ConsultantProfile": {
      "title": "ConsultantProfile",
      "description": "بيانات المستشارين المعتمدين في النظام.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "bio": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "isOnline": { "type": "boolean", "default": false }
      }
    },
    "LiveConsultation": {
      "title": "LiveConsultation",
      "description": "جلسة استشارة مباشرة بين عميل ومستشار.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "consultantId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "terminated", "completed"] },
        "startedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "جلسة محادثة مع البوت الذكي.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "characterId": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "رسالة فردية داخل جلسة محادثة.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ForbiddenWord": {
      "title": "ForbiddenWord",
      "description": "الكلمات المحظورة في النظام الرقابي.",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "ملفات المستخدمين"
    },
    "/users/{userId}/chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "جلسات محادثة المستخدم"
    },
    "/users/{userId}/chatSessions/{sessionId}/messages/{msgId}": {
      "schema": "ChatMessage",
      "description": "رسائل المحادثة"
    },
    "/consultantProfiles/{id}": {
      "schema": "ConsultantProfile",
      "description": "بيانات الخبراء"
    },
    "/liveConsultations/{id}": {
      "schema": "LiveConsultation",
      "description": "جلسات البث المباشر"
    },
    "/liveConsultations/{id}/messages/{msgId}": {
      "schema": "object",
      "description": "رسائل الدردشة اللحظية"
    },
    "/settings/moderation/forbiddenWords/{id}": {
      "schema": "ForbiddenWord",
      "description": "قائمة الكلمات المحظورة"
    }
  }
}
