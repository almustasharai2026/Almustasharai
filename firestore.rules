
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sovereign Access Helpers
    function isSignedIn() { return request.auth != null; }
    
    // وظيفة التحقق من الرتبة السيادية (Admin) - king2026
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'bishoysamy390@gmail.com' || 
        (request.auth.token.keys().contains('role') && request.auth.token.role == "admin")
      ); 
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isNotBanned() { 
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.get('isBanned', false) == false; 
    }

    // User Profile & Recursive Chat History Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'balance', 'isBanned']));
      allow delete: if isAdmin();

      // 🔥 بروتوكول سجل المحادثات السيادي - يسمح بالوصول الكامل للمالك والمستخدم
      match /chatHistory/{msgId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Consultants Registry
    match /consultants/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sovereign System Hierarchy
    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Payment Requests
    match /paymentRequests/{id} {
      allow create: if isSignedIn() && isNotBanned();
      allow read, update, delete: if isAdmin();
    }
  }
}
