
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- بروتوكول التحقق السيادي ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'bishoysamy390@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- حماية سجلات المواطنين ---
    
    match /users/{userId} {
      // المالك يرى الجميع، المواطن يرى نفسه فقط
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && !request.resource.data.diff(request.resource.data).affectedKeys().hasAny(['role', 'balance', 'isBanned']));
      allow delete: if isAdmin();

      match /chatHistory/{msgId} { 
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin()); 
      }
      
      match /verifications/{docId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // --- حماية طلبات الدفع والخزنة ---
    
    match /paymentRequests/{reqId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- حماية مجلس الخبراء والعمليات ---
    
    match /consultants/{id} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.consultantId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.consultantId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    // --- سجلات الأحداث والرقابة ---
    
    match /analytics/{id} {
      allow read, write: if isAdmin();
    }
    
    match /user_intents/{id} {
      allow read, write: if isAdmin();
    }
    
    match /system/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
