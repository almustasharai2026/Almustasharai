
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "الملف السيادي للمواطن الرقمي، يضم الهوية الرقمية ومستوى الثقة.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "digitalId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "consultant", "admin"] },
        "isBanned": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "Consultant": {
      "title": "Consultant",
      "description": "ملف الخبير المعتمد في سوق الاستشارات.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "rating": { "type": "number", "default": 5.0 },
        "isApproved": { "type": "boolean", "default": false },
        "isOnline": { "type": "boolean", "default": false }
      },
      "required": ["name", "specialization"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "المحفظة المالية السيادية للمواطن.",
      "type": "object",
      "properties": {
        "balance": { "type": "number", "default": 100 },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "سجل المعاملات المالية.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["recharge", "deduction"] },
        "service": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "بيانات الهوية السيادية"
    },
    "/consultants/{id}": {
      "schema": "Consultant",
      "description": "هيئة الخبراء المعتمدين"
    },
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "المحافظ المالية للمواطنين"
    },
    "/wallets/{userId}/transactions/{id}": {
      "schema": "Transaction",
      "description": "سجل المحاسبة المالية"
    },
    "/system/moderation/forbiddenWords/{id}": {
      "schema": "object",
      "description": "قاموس الحظر التلقائي"
    }
  }
}
