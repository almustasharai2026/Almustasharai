
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sovereign Access Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'bishoysamy390@gmail.com'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isNotBanned() { 
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && get(userPath).data.isBanned == false; 
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn();
      allow update: if (isOwner(userId) && isNotBanned() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'role', 'digitalId', 'isBanned'])) || isAdmin();
      
      match /transactions/{id} { allow read: if isOwner(userId) || isAdmin(); }
    }

    // Consultant Profiles & Sovereign Ratings
    match /consultants/{id} {
      allow read: if isSignedIn();
      allow update: if (isSignedIn() && isNotBanned() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviews'])) || isAdmin();
      allow create, delete: if isAdmin();
    }

    // Wallets & Transactions
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
      
      match /transactions/{id} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAdmin();
      }
    }

    // Bookings
    match /bookings/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn() && isNotBanned() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Payment Requests
    match /paymentRequests/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn() && isNotBanned();
      allow update, delete: if isAdmin();
    }

    // Global Moderation System
    match /system/moderation/forbiddenWords/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Live Consultations
    match /liveConsultations/{sessionId} {
      allow read, write: if isSignedIn() && isNotBanned();
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && isNotBanned();
      }
    }
  }
}
