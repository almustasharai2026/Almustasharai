
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "الملف السيادي للمواطن الرقمي، يضم الهوية الرقمية ومستوى الثقة وحالة الامتثال.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "consultant", "moderator", "admin"] },
        "balance": { "type": "number", "default": 50 },
        "trustScore": { "type": "number", "default": 50 },
        "completedSessions": { "type": "number", "default": 0 },
        "reports": { "type": "number", "default": 0 },
        "isBanned": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "إعدادات الواجهة والنصوص العامة للمنصة.",
      "type": "object",
      "properties": {
        "homeTitle": { "type": "string" },
        "homeSubtitle": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "PricingOffer": {
      "title": "PricingOffer",
      "description": "باقة شحن رصيد سيادية.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "minutes": { "type": "number" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "isPopular": { "type": "boolean" },
        "icon": { "type": "string" }
      }
    },
    "Consultant": {
      "title": "Consultant",
      "description": "ملف الخبير المعتمد في هيئة الاستشارات.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "rating": { "type": "number", "default": 5.0 },
        "reviews": { "type": "number", "default": 0 },
        "isApproved": { "type": "boolean", "default": true }
      },
      "required": ["name", "specialization"]
    },
    "ModerationWord": {
      "title": "ModerationWord",
      "description": "كلمة محظورة يراقبها الدرع الواقي السيادي.",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "بيانات الهوية السيادية"
    },
    "/system/settings": {
      "schema": "SystemSettings",
      "description": "إعدادات المنصة المركزية"
    },
    "/system/config/offers/{offerId}": {
      "schema": "PricingOffer",
      "description": "باقات الأسعار السيادية المحدثة"
    },
    "/consultants/{id}": {
      "schema": "Consultant",
      "description": "هيئة الخبراء المعتمدين"
    },
    "/system/moderation/forbiddenWords/{id}": {
      "schema": "ModerationWord",
      "description": "قاعدة بيانات الكلمات المحظورة"
    }
  }
}
