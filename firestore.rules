
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // بروتوكول التحقق السيادي king2026
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'bishoysamy390@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // المواطنون
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
      
      // السماح بالقائمة (list) فقط للأدمن أو إذا كان المستخدم يطلب سجله الخاص
      allow list: if isAdmin();

      match /chatHistory/{msgId} { 
        allow read, write: if request.auth.uid == userId || isAdmin(); 
      }
    }

    // نظام الحجز والجدولة (Sovereign Booking System)
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.consultantId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.consultantId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // طلبات الدفع
    match /paymentRequests/{reqId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /consultants/{id} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    
    match /roles_admin/{userId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    // سجلات الأحداث والتحليلات
    match /analytics/{id} {
      allow read, write: if isAdmin();
    }
    
    match /system/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
