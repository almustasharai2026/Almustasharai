rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sovereign Access Helpers
    function isSignedIn() { return request.auth != null; }
    
    // وظيفة التحقق من الرتبة السيادية (Admin)
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'bishoysamy390@gmail.com' || 
        request.auth.token.role == "admin"
      ); 
    }
    
    function isModerator() { 
      return isSignedIn() && (
        request.auth.token.role == "moderator" || 
        request.auth.token.email.matches('.*moderator.*')
      ); 
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // بروتوكول التحقق من حالة المواطن (Resilient Banned Check)
    function isNotBanned() { 
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.get('isBanned', false) == false; 
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isModerator();
      allow create: if isSignedIn();
      allow update: if (isOwner(userId) && isNotBanned()) || isAdmin();
    }

    // Wallets Protocol (Sovereign Financial Security)
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
      
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // Bookings Protocol
    match /bookings/{id} {
      allow create, read: if isSignedIn() && isNotBanned();
      allow update, delete: if isAdmin() || isModerator();
    }

    // Consultants Registry
    match /consultants/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Global Moderation System
    match /system/moderation/forbiddenWords/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isModerator();
    }
    
    // System Core Settings
    match /system/settings {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /system/offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Live Consultations
    match /liveConsultations/{sessionId} {
      allow read, write: if isSignedIn() && isNotBanned();
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && isNotBanned();
      }
    }

    // Analytics Protocol
    match /analytics/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || isModerator();
    }
  }
}