
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sovereign Access Helpers
    function isSignedIn() { return request.auth != null; }
    
    // وظيفة التحقق من الرتبة السيادية (Admin) - king2026
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'bishoysamy390@gmail.com' || 
        (request.auth.token.keys().contains('role') && request.auth.token.role == "admin")
      ); 
    }
    
    function isModerator() { 
      return isSignedIn() && (
        (request.auth.token.keys().contains('role') && request.auth.token.role == "moderator")
      ); 
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isNotBanned() { 
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.get('isBanned', false) == false; 
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isModerator();
      allow create: if isSignedIn();
      // المالك فقط يمكنه تعديل الرصيد والرتبة وحالة الحظر
      allow update: if isAdmin() || (isOwner(userId) && isNotBanned() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'balance', 'isBanned']));
      allow delete: if isAdmin();
    }

    // Consultants Registry
    match /consultants/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sovereign System Hierarchy (Logs, Moderation, Config)
    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Live Consultations & Bookings
    match /liveConsultations/{sessionId} {
      allow read, write: if isSignedIn() && isNotBanned();
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && isNotBanned();
      }
    }
    
    match /bookings/{id} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && isNotBanned();
      allow update, delete: if isAdmin();
    }

    // Payment Requests
    match /paymentRequests/{id} {
      allow create: if isSignedIn() && isNotBanned();
      allow read, update, delete: if isAdmin();
    }

    // Analytics (Restricted)
    match /analytics/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || isModerator();
    }
  }
}
