
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ميثاق الحماية السيادي (Supreme Security Protocol king2026).
     * يسمح للمواطنين والمديرين بالوصول الكامل لمسارات البيانات المحددة.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // المواطنون وإدارة الهوية
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // سجل التوثيق السيادي - مفتوح للطرفين
      match /chatHistory/{msgId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // محادثات التحكم السيادية
      match /sovereignChat/{msgId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // هيئة الخبراء
    match /consultants/{consultantId} {
      allow read: if true;
      allow write: if isOwner(consultantId) || isAdmin();
    }

    // الحجوزات والتعاملات
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // طلبات الدفع والشحن
    match /paymentRequests/{reqId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // محادثات البث المباشر
    match /liveConsultations/{sessionId} {
      allow read, write: if isSignedIn();
      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // الصلاحيات العليا
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
