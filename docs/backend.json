
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "بيانات المستخدم الأساسية والرصيد المالي وحالة الحظر.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isBanned": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "balance", "role"]
    },
    "ConsultantProfile": {
      "title": "ConsultantProfile",
      "description": "بيانات المستشارين المعتمدين في النظام.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "bio": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "isOnline": { "type": "boolean", "default": false }
      }
    },
    "LiveConsultation": {
      "title": "LiveConsultation",
      "description": "جلسة استشارة مباشرة بين عميل ومستشار.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "consultantId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "terminated", "completed"] },
        "startedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ForbiddenWord": {
      "title": "ForbiddenWord",
      "description": "الكلمات المحظورة في النظام الرقابي.",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "ملفات المستخدمين"
    },
    "/consultantProfiles/{id}": {
      "schema": "ConsultantProfile",
      "description": "بيانات الخبراء"
    },
    "/liveConsultations/{id}": {
      "schema": "LiveConsultation",
      "description": "جلسات البث المباشر"
    },
    "/liveConsultations/{id}/messages/{msgId}": {
      "schema": "object",
      "description": "رسائل الدردشة اللحظية"
    },
    "/settings/moderation/forbiddenWords/{id}": {
      "schema": "ForbiddenWord",
      "description": "قائمة الكلمات المحظورة"
    }
  }
}
